<style>
:root{
  --neon:#00f2ff;--neon2:#bc13fe;--neon-dim:rgba(0,242,255,0.12);
  --bg:#000;--panel:#080808;--border:#161616;--green:#00b67a;
  --text:#ffffff;--muted:#555;--err:#ff4d4f;
  --gold:#ffd700;--gold-light:#ffed4e;--brown:#8B4513;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-font-smoothing:antialiased}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;overflow-x:hidden}
a:focus-visible,button:focus-visible,input:focus-visible{outline:2px solid var(--neon);outline-offset:2px}

/* TICKER */
.ticker-wrap{position:fixed;top:0;width:100%;z-index:9500;background:#000;border-bottom:1px solid #0f0f0f}
.ticker-row{overflow:hidden;white-space:nowrap;padding:7px 0}
.ticker-inner{display:inline-block;animation:tickL 30s linear infinite;font-family:'Orbitron';font-size:8.5px;letter-spacing:1.5px;color:#555}
.ticker-inner span{margin-right:55px}
.ticker-inner .hl{color:var(--gold)}
@keyframes tickL{from{transform:translateX(0)}to{transform:translateX(-50%)}}
@media(prefers-reduced-motion:reduce){.ticker-inner{animation:none}}

/* HEADER */
header{position:fixed;top:30px;width:100%;z-index:9400;padding:11px 5%;display:flex;align-items:center;justify-content:space-between;background:rgba(0,0,0,0.95);backdrop-filter:blur(22px);border-bottom:1px solid #0d0d0d}
.brand{font-family:'Orbitron';font-weight:900;font-size:1.1rem;letter-spacing:5px;color:#fff;text-decoration:none;background:linear-gradient(90deg,var(--gold),#fff);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
.nav-ctrl{display:flex;align-items:center;gap:18px}
.cart-btn{cursor:pointer;display:flex;align-items:center;gap:7px;padding:7px 14px;border:1px solid #1a1a1a;border-radius:6px;font-family:'Orbitron';font-size:9px;color:#888;transition:.3s;background:transparent}
.cart-btn:hover{border-color:var(--gold);color:var(--gold)}
.cart-badge{background:var(--gold);color:#000;font-size:8px;font-weight:900;min-width:17px;height:17px;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 0 8px var(--gold)}
.burger{cursor:pointer;width:22px;height:14px;display:flex;flex-direction:column;justify-content:space-between;background:none;border:none;padding:0}
.burger div{height:1.5px;background:#fff;transition:.3s;border-radius:1px}

/* FULL NAV */
#full-nav{position:fixed;inset:0;background:rgba(0,0,0,.97);z-index:40000;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:18px;transform:translateX(100%);transition:.55s cubic-bezier(.7,0,.3,1);backdrop-filter:blur(30px)}
#full-nav.active{transform:translateX(0)}
.nav-link{font-family:'Orbitron';font-size:1.25rem;text-decoration:none;color:#fff;transition:.3s;letter-spacing:3px;background:none;border:none;cursor:pointer}
.nav-link:hover{color:var(--gold)}

/* CART DRAWER */
#cart-drawer{position:fixed;top:0;right:-520px;width:100%;max-width:480px;height:100%;background:#050505;z-index:100001;transition:.5s cubic-bezier(.7,0,.3,1);border-left:1px solid #0f0f0f;display:flex;flex-direction:column;box-shadow:-20px 0 80px rgba(0,0,0,.95)}
#cart-drawer.open{right:0}
.c-overlay{position:fixed;inset:0;background:rgba(0,0,0,.78);z-index:100000;display:none;backdrop-filter:blur(10px)}
.cart-hd{padding:20px 22px;border-bottom:1px solid #0f0f0f;display:flex;justify-content:space-between;align-items:center;background:#070707;flex-shrink:0}
.cart-hd-title{font-family:'Orbitron';font-size:10px;letter-spacing:3px}
.cart-x{width:30px;height:30px;border:1px solid #1a1a1a;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:18px;color:#555;transition:.2s;background:none}
.cart-x:hover{color:#fff;border-color:#333}
.cart-scroll{flex:1;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch}
.cart-scroll::-webkit-scrollbar{width:3px}
.cart-scroll::-webkit-scrollbar-thumb{background:#1a1a1a;border-radius:3px}
.cart-body{padding:15px 22px}
.c-item{display:flex;gap:13px;margin-bottom:11px;background:#0c0c0c;padding:13px;border-radius:10px;border:1px solid #111;animation:cartIn .3s ease-out}
@keyframes cartIn{from{opacity:0;transform:translateX(20px)}to{opacity:1;transform:translateX(0)}}
.c-item img{width:54px;height:54px;object-fit:contain;background:#0f0f0f;border-radius:6px;flex-shrink:0}
.c-item-info{flex:1;min-width:0}
.c-item-info h4{font-family:'Orbitron';font-size:8.5px;letter-spacing:.8px;margin-bottom:3px}
.c-qty{display:flex;align-items:center;gap:7px;margin-top:7px}
.qty-b{width:20px;height:20px;border:1px solid #1a1a1a;border-radius:4px;cursor:pointer;background:#111;color:#fff;font-size:12px;display:flex;align-items:center;justify-content:center;transition:.2s}
.qty-b:hover{border-color:var(--gold);color:var(--gold)}
.qty-n{font-family:'Orbitron';font-size:9px;min-width:18px;text-align:center}
.c-empty{text-align:center;padding:60px 20px;color:#222}
.c-empty p{font-family:'Orbitron';font-size:9px;letter-spacing:2px;margin-top:12px}
.cart-ft{border-top:1px solid #0f0f0f;padding:18px 22px 90px;background:#050505}
.ship-bar-lbl{font-family:'Orbitron';font-size:7.5px;letter-spacing:1.5px;color:#444;margin-bottom:5px}
.ship-bar{background:#0d0d0d;border-radius:3px;height:3px;margin-bottom:14px;overflow:hidden}
.ship-fill{height:100%;background:var(--gold);border-radius:3px;transition:.5s}
.sum-row{display:flex;justify-content:space-between;font-size:10.5px;color:#666;margin-bottom:5px;font-family:'Inter'}
.sum-row.total{color:#fff;font-weight:700;font-size:13px;border-top:1px solid #0f0f0f;padding-top:9px;margin-top:6px;font-family:'Orbitron'}
.land-row{display:flex;align-items:center;gap:10px;margin:10px 0;background:#0c0c0c;border:1px solid #111;border-radius:8px;padding:10px 13px}
.land-lbl{font-family:'Orbitron';font-size:7.5px;color:#555;letter-spacing:1.5px;white-space:nowrap}
.land-sel{flex:1;background:#111;border:1px solid #1a1a1a;color:#fff;font-family:'Orbitron';font-size:8.5px;padding:7px 10px;border-radius:5px;outline:none;cursor:pointer}
.land-sel:focus{border-color:var(--gold)}
.discount-row{display:flex;gap:8px;margin:10px 0}
.discount-input{flex:1;padding:9px 12px;background:#0c0c0c;border:1px solid #1a1a1a;color:#fff;font-family:'Orbitron';font-size:8.5px;border-radius:6px;outline:none;letter-spacing:1px;text-transform:uppercase}
.discount-input:focus{border-color:var(--gold)}
.discount-btn{padding:9px 15px;background:transparent;border:1px solid #2a2a2a;color:#888;font-family:'Orbitron';font-size:8px;letter-spacing:1px;border-radius:6px;cursor:pointer;transition:.3s;white-space:nowrap}
.discount-btn:hover{border-color:var(--gold);color:var(--gold)}
.discount-ok{font-family:'Orbitron';font-size:7.5px;color:var(--green);letter-spacing:1px;display:none;margin-top:4px}
.discount-err{font-family:'Orbitron';font-size:7.5px;color:var(--err);letter-spacing:1px;display:none;margin-top:4px}
.legal-note{font-size:8.5px;color:#333;margin:10px 0;line-height:1.6}
.legal-note a{color:var(--gold)}
.agb-check{display:flex;align-items:flex-start;gap:8px;font-size:8.5px;color:#555;margin:9px 0;cursor:pointer}
.agb-check input{accent-color:var(--gold);margin-top:1px;flex-shrink:0;width:14px;height:14px}
.agb-check a{color:var(--gold)}
.or-div{text-align:center;font-family:'Orbitron';font-size:7.5px;color:#222;letter-spacing:2px;margin:14px 0 8px;position:relative}
.or-div::before,.or-div::after{content:'';position:absolute;top:50%;width:38%;height:1px;background:#0f0f0f}
.or-div::before{left:0}.or-div::after{right:0}
.vat-lbl{font-size:7.5px;text-align:center;margin-top:8px;color:#1f1f1f;font-family:'Orbitron'}

/* ORDER SUCCESS */
#order-success-modal{position:fixed;inset:0;background:rgba(0,0,0,.97);z-index:300000;display:none;align-items:center;justify-content:center;backdrop-filter:blur(20px);padding:20px}
.success-box{background:#060606;border:2px solid var(--gold);border-radius:20px;padding:45px;max-width:480px;width:100%;text-align:center;position:relative;overflow:hidden}
.check-circle{width:70px;height:70px;border:2px solid var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;animation:pulsCheck 2s infinite;font-size:28px;color:var(--gold)}
@keyframes pulsCheck{0%,100%{box-shadow:0 0 0 0 rgba(255,215,0,.4)}50%{box-shadow:0 0 0 15px rgba(255,215,0,0)}}
.success-title{font-family:'Orbitron';font-size:1rem;letter-spacing:4px;color:var(--gold);margin-bottom:10px}
.success-sub{font-size:11px;color:#666;line-height:1.7;margin-bottom:25px}
.success-order-nr{font-family:'Orbitron';font-size:9px;color:#333;letter-spacing:2px;margin-bottom:20px}
.success-btn{padding:13px 30px;background:var(--gold);color:#000;border:none;font-family:'Orbitron';font-weight:900;font-size:9px;letter-spacing:2px;cursor:pointer;border-radius:8px}
.success-btn:hover{background:#fff}

/* TOAST */
#toasts{position:fixed;bottom:30px;right:28px;z-index:600000;display:flex;flex-direction:column;gap:9px;pointer-events:none}
.toast{background:#0c0c0c;border:1px solid #1a1a1a;border-left:3px solid var(--gold);padding:12px 16px;border-radius:8px;font-family:'Orbitron';font-size:8.5px;letter-spacing:1px;min-width:210px;animation:toastIn .4s cubic-bezier(.175,.885,.32,1.275);box-shadow:0 10px 40px rgba(0,0,0,.9)}
.toast.err{border-left-color:var(--err)}
.toast.ok{border-left-color:var(--green)}
@keyframes toastIn{from{transform:translateX(80px);opacity:0}to{transform:translateX(0);opacity:1}}

/* BACKGROUNDS */
#star-canvas{position:fixed;inset:0;z-index:-2;background:#000}
#particle-canvas{position:fixed;inset:0;z-index:-1;pointer-events:none;opacity:.6}

/* HERO */
#hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:120px 5% 60px;text-align:center;position:relative;z-index:1}
.hero-eyebrow{font-family:'Orbitron';font-size:8px;letter-spacing:6px;color:var(--gold);opacity:.75;margin-bottom:14px;animation:heroUp .8s ease .3s both}
.hero-headline{font-family:'Orbitron';font-size:clamp(2.5rem,10vw,6.5rem);font-weight:900;letter-spacing:-3px;line-height:.9;margin-bottom:16px;animation:heroUp .8s ease .5s both;background:linear-gradient(135deg,var(--gold),#ffed4e,var(--gold));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
.hero-sub{font-family:'Orbitron';font-size:9px;color:#555;letter-spacing:4px;margin-bottom:40px;animation:heroUp .8s ease .7s both}
.hero-ctas{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-bottom:50px;animation:heroUp .8s ease .9s both}
.hero-btn-main{display:inline-flex;align-items:center;gap:10px;padding:16px 36px;background:linear-gradient(135deg,var(--gold),#ffed4e);color:#000;border:none;font-family:'Orbitron';font-weight:900;font-size:10px;letter-spacing:2px;cursor:pointer;border-radius:10px;text-decoration:none;transition:.3s;box-shadow:0 0 30px rgba(255,215,0,.4),0 0 60px rgba(255,215,0,.1)}
.hero-btn-main:hover{transform:translateY(-2px);box-shadow:0 0 50px rgba(255,215,0,.6),0 0 100px rgba(255,215,0,.2)}
.hero-btn-sec{display:inline-flex;align-items:center;gap:10px;padding:16px 36px;background:transparent;color:var(--gold);border:2px solid var(--gold);font-family:'Orbitron';font-weight:700;font-size:10px;letter-spacing:2px;cursor:pointer;border-radius:10px;text-decoration:none;transition:.3s}
.hero-btn-sec:hover{background:rgba(255,215,0,.08);border-color:var(--gold);transform:translateY(-2px)}
.float-logo{width:240px;max-width:60vw;filter:drop-shadow(0 0 22px var(--gold));animation:floatY 4s ease-in-out infinite;margin-bottom:22px}
@keyframes floatY{0%,100%{transform:translateY(0)}50%{transform:translateY(-13px)}}
.hero-banner{width:90%;max-width:800px;border-radius:14px;border:2px solid var(--gold);filter:drop-shadow(0 0 28px rgba(255,215,0,.25));animation:floatY 4.5s ease-in-out infinite;animation-delay:.6s;margin-bottom:44px}
.hero-stats{display:flex;gap:44px;justify-content:center;flex-wrap:wrap;animation:heroUp .8s ease 1.1s both}
.hero-stat-num{font-family:'Orbitron';font-size:1.9rem;font-weight:900;color:var(--gold);text-shadow:0 0 20px rgba(255,215,0,.4);line-height:1}
.hero-stat-lbl{font-family:'Orbitron';font-size:7px;color:#444;letter-spacing:2px;margin-top:5px}
@keyframes heroUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}

/* FEATURES */
.features-strip{padding:50px 5%;border-top:1px solid #0a0a0a;border-bottom:1px solid #0a0a0a;background:linear-gradient(180deg,#030303,#000);position:relative;z-index:1}
.features-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(175px,1fr));gap:18px;max-width:1200px;margin:0 auto}
.feat-card{text-align:center;padding:22px 14px;background:rgba(255,215,0,.02);border:1px solid #0f0f0f;border-radius:12px;transition:.3s}
.feat-card:hover{border-color:rgba(255,215,0,.3);background:rgba(255,215,0,.05);transform:translateY(-3px)}
.feat-icon{font-size:26px;margin-bottom:10px}
.feat-title{font-family:'Orbitron';font-size:8.5px;color:var(--gold);letter-spacing:2px;margin-bottom:5px}
.feat-desc{font-size:10.5px;color:#555;line-height:1.5}

/* SECTIONS */
.sec-title{font-family:'Orbitron';font-size:clamp(.9rem,3vw,1.3rem);letter-spacing:6px;text-align:center;margin-bottom:8px;color:var(--gold)}
.sec-sub{font-size:9.5px;color:#444;text-align:center;letter-spacing:3px;font-family:'Orbitron';margin-bottom:45px}

/* PRODUCTS */
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(270px,1fr));gap:26px;padding:40px 5%;max-width:1400px;margin:0 auto}
.card{background:var(--panel);padding:24px;border-radius:14px;border:1px solid #0f0f0f;transition:.4s;position:relative;overflow:hidden}
.card::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 50% 0%,rgba(255,215,0,.03),transparent 70%);pointer-events:none}
.card:hover{border-color:var(--gold);box-shadow:0 0 35px rgba(255,215,0,.18);transform:translateY(-5px)}
.card img{width:100%;border-radius:8px;object-fit:contain;max-height:190px;margin-bottom:13px}
.card h3{font-family:'Orbitron';font-size:10px;letter-spacing:2px}
.c-price{color:var(--gold);font-family:'Orbitron';font-size:14px;font-weight:700;margin:8px 0}
.wish-btn{position:absolute;top:13px;right:13px;width:30px;height:30px;border:1px solid #1a1a1a;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;background:rgba(0,0,0,.7);transition:.3s;z-index:2}
.wish-btn:hover,.wish-btn.on{border-color:#ff4d7d}
.wish-btn.on svg path{fill:#ff4d7d;stroke:#ff4d7d}
.dbox{margin:11px 0;padding:11px 13px;background:rgba(255,215,0,.04);border-left:3px solid var(--gold);border-radius:6px;display:flex;align-items:center;gap:10px;border-right:1px solid #0f0f0f;border-top:1px solid #0f0f0f;border-bottom:1px solid #0f0f0f;transition:.3s}
.dbox:hover{background:rgba(255,215,0,.09)}
.dbox-lbl{font-family:'Orbitron';font-size:6.5px;color:var(--gold);letter-spacing:2px;text-transform:uppercase}
.dbox-date{font-size:10.5px;color:#fff;font-family:'Inter';font-weight:500}
.btn{width:100%;padding:13px;background:#fff;color:#000;border:none;font-family:'Orbitron';font-weight:900;cursor:pointer;text-transform:uppercase;transition:.3s;border-radius:8px;font-size:9.5px;letter-spacing:1.5px;display:flex;align-items:center;justify-content:center;gap:7px}
.btn:hover{background:var(--gold)}
.btn.outline{background:transparent;border:1px solid var(--gold);color:var(--gold)}
.btn.outline:hover{background:var(--gold);color:#000}

/* EMAIL MARKETING */
#email-marketing{padding:80px 5%;text-align:center;position:relative;overflow:hidden;background:#040404;border-top:1px solid #0a0a0a;z-index:1}
.em-glow{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:500px;height:300px;background:radial-gradient(ellipse,rgba(255,215,0,.04) 0%,transparent 70%);pointer-events:none}
.em-inner{position:relative;z-index:1;max-width:550px;margin:0 auto}
.em-form{display:flex;gap:10px;margin-top:30px}
.em-input{flex:1;padding:14px 16px;background:#0c0c0c;border:1px solid #1a1a1a;color:#fff;font-family:'Inter';font-size:12px;border-radius:8px;outline:none;transition:.3s}
.em-input:focus{border-color:var(--gold)}
.em-btn{padding:14px 24px;background:var(--gold);color:#000;border:none;font-family:'Orbitron';font-weight:900;font-size:9px;letter-spacing:1.5px;cursor:pointer;border-radius:8px;white-space:nowrap;transition:.3s;flex-shrink:0}
.em-btn:hover{background:#fff}

/* CONTACT */
#contact{padding:90px 5%;max-width:600px;margin:0 auto;text-align:center;position:relative;z-index:1}
.input-field{width:100%;padding:13px 15px;background:#040404;border:1px solid #111;color:#fff;margin-bottom:10px;font-family:'Inter';font-size:13px;outline:none;border-radius:7px;transition:.3s}
.input-field:focus{border-color:var(--gold);background:rgba(255,215,0,.02)}

/* FOOTER */
.footer{padding:55px 5%;background:linear-gradient(-45deg,var(--gold),#000,#bc13fe,#000);background-size:400% 400%;animation:footerG 12s ease infinite;border-top:1px solid rgba(255,255,255,.07);position:relative;z-index:1}
@keyframes footerG{0%{background-position:0 50%}50%{background-position:100% 50%}100%{background-position:0 50%}}
.legal-box{border:1px solid rgba(255,255,255,.1);margin-bottom:8px;border-radius:8px;background:rgba(0,0,0,.88)}
.legal-hd{padding:15px 18px;cursor:pointer;font-family:'Orbitron';font-size:8.5px;color:#ccc;display:flex;justify-content:space-between;align-items:center;letter-spacing:1.5px}
.legal-hd:hover{color:#fff}
.legal-body{max-height:0;padding:0 18px;transition:.4s;font-size:9.5px;color:#bbb;overflow:hidden;line-height:1.85}
.legal-box.open .legal-body{max-height:8000px;padding:18px;border-top:1px solid rgba(255,255,255,.07)}
.legal-body a{color:var(--gold)}
.legal-body strong{color:#fff}
.footer-bottom{text-align:center;margin-top:30px;font-family:'Orbitron';font-size:7.5px;color:rgba(255,255,255,.45);letter-spacing:3px}
.footer-links{display:flex;justify-content:center;gap:20px;flex-wrap:wrap;margin-bottom:15px}
