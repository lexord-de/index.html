    tplWrap('#DAA520','✅ NACHRICHT ERHALTEN',`<p style="font-size:14px;color:#333">Hallo <strong>${esc(name)}</strong>,</p><p style="font-size:13px;color:#666;line-height:1.7">deine Nachricht wurde erhalten. Wir antworten innerhalb von <strong>24 Stunden</strong>.</p>`),
    ADMIN_EMAIL
  ).catch(e2 => console.warn('Contact reply failed:', e2));

  setTimeout(()=>{document.getElementById('contact-form').style.display='none';document.getElementById('contact-success').style.display='block';btn.innerText='NACHRICHT SENDEN';btn.disabled=false;},800);
}

