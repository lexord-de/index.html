function toggleWish(btn,name){btn.classList.toggle('on');toast(btn.classList.contains('on')?'♥ '+name+' zur Wunschliste':name+' entfernt','ok');}

function openLegal(id){const el=document.getElementById(id);if(el){el.classList.add('open');el.scrollIntoView({behavior:'smooth',block:'center'});}}

function toast(msg,type){type=type||'ok';const t=document.createElement('div');t.className='toast '+type;t.innerText=msg;document.getElementById('toasts').appendChild(t);setTimeout(()=>{t.style.cssText='opacity:0;transform:translateX(60px);transition:.4s';setTimeout(()=>t.remove(),400);},3000);}

function setDelivery(){let d=new Date();d.setDate(d.getDate()+3);while(d.getDay()===0||d.getDay()===6)d.setDate(d.getDate()+1);const s=d.toLocaleDateString('de-DE',{day:'2-digit',month:'long'});document.querySelectorAll('.delivery-date').forEach(el=>el.innerText=s);}
setDelivery();

window.addEventListener('scroll',()=>{const el=document.getElementById('scroll-top');if(el)el.classList.toggle('vis',window.scrollY>400);});

(function(){
  const sc=document.getElementById('star-canvas');if(!sc)return;
  const sx=sc.getContext('2d');
  const rsz=()=>{sc.width=window.innerWidth;sc.height=window.innerHeight;};
  window.addEventListener('resize',rsz);rsz();
  const stars=[];for(let i=0;i<110;i++)stars.push({x:Math.random()*sc.width,y:Math.random()*sc.height,v:.05+Math.random()*.25,o:Math.random()*.8});
  function draw(){sx.clearRect(0,0,sc.width,sc.height);stars.forEach(s=>{s.y-=s.v;if(s.y<0)s.y=sc.height;sx.fillStyle='rgba(255,255,255,'+s.o+')';sx.fillRect(s.x,s.y,1,1);});requestAnimationFrame(draw);}
  draw();
})();

(function(){
  const pc=document.getElementById('particle-canvas');if(!pc)return;
  const px=pc.getContext('2d');
  const rsz=()=>{pc.width=window.innerWidth;pc.height=window.innerHeight;};
  window.addEventListener('resize',rsz);rsz();
  const pts=[];
  for(let i=0;i<90;i++){
    pts.push({
      x:Math.random()*pc.width, y:Math.random()*pc.height,
      vx:(Math.random()-.5)*.4, vy:-Math.random()*.5-.1,
      sz:Math.random()*2+.5,
      alpha:Math.random()*.4+.1,
      color:Math.random()>.55?'#bc13fe':'#DAA520'
    });
  }
  function draw(){
    px.clearRect(0,0,pc.width,pc.height);
    pts.forEach(p=>{
      p.x+=p.vx; p.y+=p.vy;
      if(p.y<-10){p.y=pc.height+10;p.x=Math.random()*pc.width;}
      if(p.x<-10)p.x=pc.width+10;
      if(p.x>pc.width+10)p.x=-10;
      px.save();
      px.globalAlpha=p.alpha;
      px.fillStyle=p.color;
      px.shadowColor=p.color;
      px.shadowBlur=10;
      px.beginPath();
      px.arc(p.x,p.y,p.sz,0,Math.PI*2);
      px.fill();
      px.restore();
    });
    requestAnimationFrame(draw);
  }
  draw();
})();

const revObs=new IntersectionObserver((entries)=>{
  entries.forEach(en=>{
    if(en.isIntersecting){
      en.target.style.transition='opacity .9s ease, transform .9s ease';
      en.target.style.opacity='1';
      en.target.style.transform='translateY(0)';
      revObs.unobserve(en.target);
    }
  });
},{threshold:.08,rootMargin:'0px 0px -40px 0px'});
document.querySelectorAll('.reveal').forEach(el=>revObs.observe(el));

loadCart();
updateCart();
</script>
