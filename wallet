<style>
:root{
  --primary:#0f1419;--secondary:#1a2332;--accent:#d4a856;
  --text:#f0f2f5;--muted:#b0b8c1;--border:#2a3647;
  --green:#1b7a4d;--red:#c1302b;--bg-light:#0a0d12
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-font-smoothing:antialiased}
html{scroll-behavior:smooth}
body{background:#fff;color:var(--text);font-family:'Roboto',sans-serif;overflow-x:hidden}

/* PROFESSIONAL HEADER */
header{position:fixed;top:0;width:100%;z-index:9400;background:#fff;border-bottom:1px solid #ddd;box-shadow:0 1px 3px rgba(0,0,0,.1);padding:14px 5%;display:flex;align-items:center;justify-content:space-between}
.brand{font-family:‘Lora’,serif;font-weight:700;font-size:1.4rem;color:var(–primary);text-decoration:none;letter-spacing:1px}
.brand-sub{font-size:7px;color:var(–accent);letter-spacing:2px;text-transform:uppercase;margin-top:2px}
.header-badges{display:flex;gap:16px;align-items:center}
.cert-badge{display:flex;align-items:center;gap:6px;font-size:8px;color:var(–primary);font-weight:600;letter-spacing:.5px;text-transform:uppercase;padding:6px 10px;border:1px solid #ddd;border-radius:4px;background:#f9f9f9}
.cert-badge::before{content:‘✓’;color:var(–accent);font-weight:900}
.nav-right{display:flex;gap:14px;align-items:center}
.cart-btn{padding:8px 14px;border:1px solid #ddd;background:#f9f9f9;color:var(–primary);cursor:pointer;font-size:9px;font-weight:600;border-radius:4px;transition:.2s;font-family:‘Roboto’}
.cart-btn:hover{border-color:var(–accent);background:#fff}
.cart-badge{width:18px;height:18px;border-radius:50%;background:var(–accent);color:#fff;display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:900}

/* CART DRAWER */
#cart-drawer{position:fixed;top:0;right:-500px;width:100%;max-width:450px;height:100%;background:#fff;z-index:100001;transition:.5s;border-left:1px solid #ddd;box-shadow:-5px 0 20px rgba(0,0,0,.08);display:flex;flex-direction:column}
#cart-drawer.open{right:0}
.c-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:100000;display:none;backdrop-filter:blur(4px)}
.cart-hd{padding:16px 18px;border-bottom:1px solid #ddd;display:flex;justify-content:space-between;align-items:center;background:#f9f9f9}
.cart-hd-title{font-family:‘Lora’,serif;font-size:11px;color:var(–primary);font-weight:700;letter-spacing:1px}
.cart-x{width:28px;height:28px;border:1px solid #ddd;border-radius:4px;display:flex;align-items:center;justify-content:center;cursor:pointer;background:transparent;color:var(–primary);font-weight:700}
.cart-x:hover{background:var(–accent);color:#fff;border-color:var(–accent)}
.cart-scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch}
.cart-body{padding:14px 16px}
.c-item{display:flex;gap:12px;margin-bottom:12px;background:#f9f9f9;padding:12px;border-radius:6px;border:1px solid #ddd;transition:.2s}
.c-item:hover{border-color:var(–accent)}
.c-item-info h4{font-family:‘Lora’,serif;font-size:9px;color:var(–primary);font-weight:700;margin-bottom:4px}
.c-item-info p{font-size:10px;color:var(–accent);font-weight:600}
.c-qty{display:flex;align-items:center;gap:8px;margin-top:8px}
.qty-b{width:20px;height:20px;border:1px solid #ddd;border-radius:3px;background:#f9f9f9;color:var(–primary);cursor:pointer;font-size:12px;display:flex;align-items:center;justify-content:center;transition:.2s;font-weight:700}
.qty-b:hover{background:var(–accent);color:#fff;border-color:var(–accent)}
.cart-ft{border-top:1px solid #ddd;padding:16px 18px 90px;background:#f9f9f9}
.sum-row{display:flex;justify-content:space-between;font-size:9px;color:var(–muted);margin-bottom:6px;padding:4px 0}
.sum-row.total{color:var(–primary);font-weight:700;font-size:11px;border-top:1px solid #ddd;padding-top:8px;margin-top:8px;font-family:‘Lora’,serif}
.land-sel,.discount-input{flex:1;background:#fff;border:1px solid #ddd;color:var(–primary);padding:8px;border-radius:4px;font-size:9px;font-family:‘Roboto’}
.land-sel:focus,.discount-input:focus{outline:none;border-color:var(–accent)}
.discount-btn{padding:8px 12px;background:transparent;border:1px solid #ddd;color:var(–primary);cursor:pointer;border-radius:4px;transition:.2s;font-weight:600;font-size:8px}
.discount-btn:hover{background:var(–accent);color:#fff;border-color:var(–accent)}

/* ORDER SUCCESS */
#order-success-modal{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:300000;display:none;align-items:center;justify-content:center;padding:20px;backdrop-filter:blur(8px)}
.success-box{background:#fff;border:1px solid #ddd;border-radius:8px;padding:40px;max-width:480px;width:100%;text-align:center;box-shadow:0 10px 40px rgba(0,0,0,.15)}
.check-circle{width:70px;height:70px;border:2px solid var(–green);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;font-size:36px;color:var(–green)}
.success-title{font-family:‘Lora’,serif;font-size:1.2rem;color:var(–primary);margin-bottom:12px;font-weight:700}
.success-sub{font-size:10px;color:var(–muted);line-height:1.7;margin-bottom:20px}
.success-order{font-family:‘IBM Plex Mono’,monospace;font-size:8px;color:var(–accent);letter-spacing:1px;margin:12px 0;background:#f9f9f9;padding:12px;border-radius:4px;font-weight:600}
.success-btn{padding:12px 28px;background:var(–accent);color:#fff;border:none;font-family:‘Lora’,serif;font-weight:700;font-size:10px;cursor:pointer;border-radius:4px}
.success-btn:hover{background:#c99d4f}

/* TOAST */
#toasts{position:fixed;bottom:30px;right:20px;z-index:600000;display:flex;flex-direction:column;gap:8px;pointer-events:none}
.toast{background:var(–primary);color:#fff;border:1px solid #2a3647;border-left:3px solid var(–accent);padding:12px 16px;border-radius:4px;font-family:‘IBM Plex Mono’,monospace;font-size:8px;letter-spacing:.5px;min-width:220px;box-shadow:0 4px 12px rgba(0,0,0,.2)}

/* HERO CORPORATE */
#hero{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:140px 5% 60px;text-align:center;position:relative;background:linear-gradient(135deg,#fff 0%,#f9f9f9 100%);border-bottom:1px solid #ddd}
#hero::before{content:’’;position:absolute;top:0;right:0;width:400px;height:400px;background:url(‘data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22%3E%3Ccircle cx=%2250%22 cy=%2250%22 r=%2230%22 fill=%22%23d4a856%22 opacity=%22.03%22/%3E%3C/svg%3E’);pointer-events:none}
.hero-content{position:relative;z-index:1;max-width:700px}
.hero-overline{font-family:‘IBM Plex Mono’,monospace;font-size:8px;letter-spacing:3px;color:var(–accent);margin-bottom:12px;text-transform:uppercase;font-weight:600}
.hero-headline{font-family:‘Lora’,serif;font-size:clamp(2.4rem,6vw,3.8rem);font-weight:700;line-height:1.1;margin-bottom:12px;color:var(–primary);letter-spacing:-1px}
.hero-sub{font-size:10px;color:var(–muted);letter-spacing:2px;margin-bottom:32px;text-transform:uppercase}
.hero-ctas{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:50px}
.hero-btn{display:inline-block;padding:12px 32px;border:none;font-family:‘Lora’,serif;font-weight:700;font-size:10px;letter-spacing:1px;cursor:pointer;border-radius:4px;text-decoration:none;transition:.3s;text-transform:uppercase}
.hero-btn-main{background:var(–accent);color:#fff}
.hero-btn-main:hover{background:#c99d4f}
.hero-btn-sec{background:transparent;border:2px solid var(–accent);color:var(–accent)}
.hero-btn-sec:hover{background:var(–accent);color:#fff}
.hero-stats{display:flex;gap:50px;justify-content:center;flex-wrap:wrap;margin-top:40px;padding-top:30px;border-top:1px solid #ddd}
.hero-stat{text-align:center}
.hero-stat-num{font-family:‘Lora’,serif;font-size:2rem;font-weight:700;color:var(–accent)}
.hero-stat-lbl{font-size:8px;color:var(–muted);margin-top:6px;letter-spacing:.5px;text-transform:uppercase}

/* TRUST SECTION */
.trust-section{padding:50px 5%;background:var(–primary);border-top:1px solid #ddd}
.trust-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:18px;max-width:1200px;margin:0 auto}
.trust-item{text-align:center;padding:20px;background:var(–secondary);border:1px solid var(–border);border-radius:6px;transition:.3s}
.trust-item:hover{border-color:var(–accent);background:rgba(212,168,86,.05)}
.trust-icon{font-size:28px;margin-bottom:10px}
.trust-label{font-family:‘IBM Plex Mono’,monospace;font-size:8px;color:var(–accent);letter-spacing:1px;font-weight:600;margin-bottom:6px;text-transform:uppercase}
.trust-desc{font-size:9px;color:var(–muted);line-height:1.5}

/* FEATURES */
.features-section{padding:60px 5%;background:#fff;border-bottom:1px solid #ddd}
.section-title{font-family:‘Lora’,serif;font-size:clamp(1.2rem,3vw,1.6rem);font-weight:700;text-align:center;color:var(–primary);margin-bottom:6px;letter-spacing:-.5px}
.section-sub{font-size:9px;color:var(–muted);text-align:center;letter-spacing:2px;margin-bottom:40px;text-transform:uppercase}
.features-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:20px;max-width:1200px;margin:0 auto}
.feat-card{padding:20px;background:#f9f9f9;border:1px solid #ddd;border-radius:6px;transition:.3s;text-align:center}
.feat-card:hover{border-color:var(–accent);background:#fff}
.feat-icon{font-size:28px;margin-bottom:10px}
.feat-title{font-family:‘Lora’,serif;font-size:10px;color:var(–primary);font-weight:700;margin-bottom:8px}
.feat-desc{font-size:9px;color:var(–muted);line-height:1.6}

/* PRODUCTS */
.products-section{padding:60px 5%;background:var(–primary)}
.products-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:24px;max-width:1200px;margin:0 auto}
.product-card{background:var(–secondary);border:1px solid var(–border);border-radius:8px;padding:24px;transition:.3s;display:flex;flex-direction:column}
.product-card:hover{border-color:var(–accent);box-shadow:0 8px 24px rgba(212,168,86,.1)}
.product-badge{display:inline-block;background:var(–accent);color:#fff;padding:4px 10px;border-radius:3px;font-family:‘IBM Plex Mono’,monospace;font-size:7px;font-weight:700;margin-bottom:12px;width:fit-content;text-transform:uppercase;letter-spacing:.5px}
.product-img{width:100%;height:160px;object-fit:contain;margin-bottom:16px}
.product-name{font-family:‘Lora’,serif;font-size:11px;color:var(–accent);font-weight:700;margin-bottom:6px}
.product-desc{font-size:9px;color:var(–muted);margin-bottom:12px;line-height:1.6}
.product-specs{font-size:8px;color:var(–muted);margin-bottom:12px;line-height:1.5;font-family:‘IBM Plex Mono’,monospace}
.product-price{font-family:‘Lora’,serif;font-size:1.8rem;color:var(–accent);font-weight:700;margin:12px 0}
.product-rating{font-size:8px;color:var(–muted);margin-bottom:12px}
.guarantee-badge{background:rgba(212,168,86,.08);border:1px solid var(–border);border-left:3px solid var(–accent);padding:10px;margin-bottom:12px;border-radius:4px;font-size:8px;color:var(–muted);font-family:‘IBM Plex Mono’,monospace}
.guarantee-badge strong{color:var(–accent)}
.btn{width:100%;padding:12px;background:var(–accent);color:#fff;border:none;font-family:‘Lora’,serif;font-weight:700;cursor:pointer;border-radius:4px;font-size:10px;letter-spacing:1px;transition:.3s;margin-top:auto;text-transform:uppercase}
.btn:hover{background:#c99d4f}

/* ABOUT SECTION */
.about-section{padding:70px 5%;background:#fff;border-bottom:1px solid #ddd}
.about-container{max-width:900px;margin:0 auto}
.about-text{font-size:10px;color:var(–muted);line-height:1.9;margin-bottom:24px;text-align:justify}
.about-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:24px;margin-top:32px}
.about-item{background:#f9f9f9;padding:20px;border:1px solid #ddd;border-radius:6px;border-left:4px solid var(–accent)}
.about-item-title{font-family:‘Lora’,serif;font-size:11px;color:var(–primary);font-weight:700;margin-bottom:8px}
.about-item-text{font-size:9px;color:var(–muted);line-height:1.6}

/* TESTIMONIALS */
.testimonials-section{padding:60px 5%;background:var(–primary);border-bottom:1px solid var(–border)}
.testimonials-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px;max-width:1200px;margin:0 auto}
.testimonial{background:var(–secondary);border:1px solid var(–border);padding:20px;border-radius:6px;transition:.3s}
.testimonial:hover{border-color:var(–accent)}
.testimonial-stars{color:var(–accent);font-size:12px;margin-bottom:10px}
.testimonial-text{font-size:9px;color:var(–muted);line-height:1.8;margin-bottom:12px;font-style:italic}
.testimonial-author{font-family:‘IBM Plex Mono’,monospace;font-size:8px;color:var(–accent);font-weight:600}
.testimonial-title{font-size:8px;color:var(–muted)}

/* GUARANTEE SECTION */
.guarantee-section{padding:60px 5%;background:#fff;border-bottom:1px solid #ddd}
.guarantee-container{max-width:900px;margin:0 auto;background:#f9f9f9;border:2px solid #ddd;border-radius:8px;padding:40px}
.guarantee-title{font-family:‘Lora’,serif;font-size:1.4rem;color:var(–primary);font-weight:700;margin-bottom:28px;text-align:center}
.guarantee-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:24px}
.guarantee-item{text-align:center}
.guarantee-item::before{content:‘✓’;font-size:28px;color:var(–green);display:block;margin-bottom:10px;font-weight:700}
.guarantee-item-title{font-family:‘Lora’,serif;font-size:10px;color:var(–primary);font-weight:700;margin-bottom:8px}
.guarantee-item-text{font-size:9px;color:var(–muted);line-height:1.6}

/* FAQ */
.faq-section{padding:60px 5%;background:var(–primary);border-bottom:1px solid var(–border)}
.faq-container{max-width:800px;margin:0 auto}
.faq-item{background:var(–secondary);border:1px solid var(–border);margin-bottom:12px;border-radius:6px;overflow:hidden}
.faq-question{padding:16px;cursor:pointer;font-family:‘Lora’,serif;font-size:10px;color:var(–primary);font-weight:700;display:flex;justify-content:space-between;align-items:center;background:var(–secondary);transition:.3s}
.faq-question:hover{background:rgba(212,168,86,.08)}
.faq-answer{max-height:0;overflow:hidden;transition:.3s;padding:0 16px}
.faq-item.open .faq-answer{max-height:800px;padding:16px}
.faq-answer{font-size:9px;color:var(–muted);line-height:1.8}

/* CONTACT */
#contact{padding:60px 5%;background:#fff;text-align:center;border-bottom:1px solid #ddd}
.contact-container{max-width:600px;margin:0 auto}
.contact-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax:180px,1fr));gap:18px;margin-bottom:40px}
.contact-box{background:#f9f9f9;padding:16px;border:1px solid #ddd;border-radius:6px}
.contact-label{font-family:‘IBM Plex Mono’,monospace;font-size:8px;color:var(–accent);margin-bottom:6px;text-transform:uppercase;font-weight:600}
.contact-value{font-size:9px;color:var(–muted)}
.contact-value a{color:var(–accent);text-decoration:none;transition:.2s}
.contact-value a:hover{text-decoration:underline}
.form-group{margin-bottom:12px}
.input-field{width:100%;padding:10px 12px;background:#f9f9f9;border:1px solid #ddd;color:var(–primary);font-family:‘Roboto’;font-size:10px;border-radius:4px;outline:none}
.input-field:focus{border-color:var(–accent)}
textarea.input-field{min-height:120px;resize:vertical}

/* FOOTER */
.footer{padding:50px 5%;background:var(–primary);border-top:1px solid var(–border)}
.footer-content{max-width:1200px;margin:0 auto}
.footer-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax:200px,1fr));gap:30px;margin-bottom:30px}
.footer-col h3{font-family:‘Lora’,serif;font-size:10px;color:var(–accent);margin-bottom:12px;font-weight:700;letter-spacing:.5px}
.footer-col p,.footer-col a{font-size:8px;color:var(–muted);line-height:1.8;text-decoration:none;transition:.2s}
.footer-col a:hover{color:var(–accent)}
.footer-divider{border-top:1px solid var(–border);margin:30px 0;padding:20px 0 0}
.footer-legal{font-size:8px;color:var(–muted);text-align:center;line-height:1.8}
.footer-legal a{color:var(–accent);text-decoration:none}

/* SCROLL TOP */
#scroll-top{position:fixed;bottom:28px;left:28px;width:36px;height:36px;background:var(–accent);border:none;border-radius:4px;display:flex;align-items:center;justify-content:center;cursor:pointer;z-index:9000;opacity:0;transform:translateY(20px);transition:.3s;color:#fff;font-weight:700;font-size:16px}
#scroll-top.vis{opacity:1;transform:translateY(0)}
#scroll-top:hover{background:#c99d4f}

.reveal{opacity:0;transform:translateY(30px)}

@media(max-width:700px){
header{flex-wrap:wrap;gap:12px}
.header-badges{display:none}
.section-title{font-size:1.2rem}
}
</style>

</head>
<body>

<div class="c-overlay" onclick="closeCart()"></div>
<div id="toasts" aria-live="polite"></div>

<!-- ORDER SUCCESS -->

<div id="order-success-modal" role="dialog" style="display:none">
  <div class="success-box">
    <div class="check-circle">✓</div>
    <div class="success-title">Bestellung bestätigt</div>
    <div class="success-sub">Vielen Dank für dein Vertrauen. Eine Bestätigung wurde gesendet an <strong id="success-email"></strong></div>
    <div class="success-order" id="success-order-nr"></div>
    <button class="success-btn" onclick="closeOrderSuccess()">Zum Shop zurück</button>
  </div>
</div>

<!-- PROFESSIONAL HEADER -->

<header>
  <div>
    <div class="brand">LXRD WALLET</div>
    <div class="brand-sub">Premium Ledertaschen | Handgefertigt in Deutschland</div>
  </div>
  <div class="header-badges">
    <div class="cert-badge">ISO 9001</div>
    <div class="cert-badge">PAYPAL TRUSTED</div>
    <div class="cert-badge">SSL SECURE</div>
  </div>
  <div class="nav-right">
    <button class="cart-btn" onclick="toggleCart()">
      🛒 WARENKORB <span id="cart-count" class="cart-badge">0</span>
    </button>
  </div>
</header>

<!-- CART DRAWER -->

<aside id="cart-drawer">
  <div class="cart-hd">
    <span class="cart-hd-title">BESTELLUNG</span>
    <button class="cart-x" onclick="closeCart()">✕</button>
  </div>
  <div class="cart-scroll">
    <div class="cart-body" id="cart-body" style="text-align:center;padding:40px 16px;color:var(--muted)">
      <p style="font-size:10px">WARENKORB LEER</p>
    </div>
    <div class="cart-ft">
      <div style="margin-bottom:14px">
        <label style="font-size:8px;color:var(--muted);display:block;margin-bottom:6px;text-transform:uppercase;font-weight:600">Land</label>
        <select class="land-sel" id="land-sel" onchange="updateCart()" style="width:100%">
          <option value="DE">🇩🇪 Deutschland</option><option value="AT">🇦🇹 Österreich</option><option value="CH">🇨🇭 Schweiz</option><option value="EU">🇪🇺 EU</option><option value="GB">🇬🇧 UK</option><option value="US">🇺🇸 USA</option>
        </select>
      </div>
      <div style="display:flex;gap:8px;margin-bottom:14px">
        <input type="text" class="discount-input" id="discount-code" placeholder="RABATTCODE">
        <button class="discount-btn" onclick="applyDiscount()">OK</button>
      </div>
      <div id="discount-ok" style="font-size:8px;color:var(--green);display:none;margin-bottom:10px"></div>
      <div id="discount-err" style="font-size:8px;color:var(--red);display:none;margin-bottom:10px"></div>
