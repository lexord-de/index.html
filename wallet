function calcDiscount(sub){if(!activeDiscount)return 0;return activeDiscount.type==='percent'?sub*activeDiscount.value/100:Math.min(activeDiscount.value,sub);}
function applyDiscount(){const code=document.getElementById('discount-code').value.trim().toUpperCase();const ok=document.getElementById('discount-ok'),err=document.getElementById('discount-err');ok.style.display='none';err.style.display='none';if(!code){err.innerText='Bitte Code eingeben';err.style.display='block';return;}const d=CODES[code];if(!d){err.innerText='✗ Ungültiger Code';err.style.display='block';activeDiscount=null;}else{activeDiscount={...d,code};ok.innerText='✓ Rabattcode aktiviert';ok.style.display='block';toast('Rabattcode '+code+' aktiviert!','ok');}updateCart();}
function loadCart(){try{const s=localStorage.getItem('lxrd_wallet_cart');if(s)cart=JSON.parse(s);}catch(e){cart=[];}}
function saveCart(){try{localStorage.setItem('lxrd_wallet_cart',JSON.stringify(cart));}catch(e){}}
function toggleCart(){document.getElementById('cart-drawer').classList.toggle('open');document.querySelector('.c-overlay').style.display='block';}
function closeCart(){document.getElementById('cart-drawer').classList.remove('open');document.querySelector('.c-overlay').style.display='none';}
function addToCart(name,price){const ex=cart.find(i=>i.name===name);if(ex)ex.qty++;else cart.push({name,price,qty:1});updateCart();if(!document.getElementById('cart-drawer').classList.contains('open'))toggleCart();toast('✓ '+name+' hinzugefügt','ok');}
function remFromCart(i){cart.splice(i,1);updateCart();}
function changeQty(i,d){cart[i].qty+=d;if(cart[i].qty<=0)cart.splice(i,1);updateCart();}
function updateCart(){
  saveCart();const body=document.getElementById('cart-body');const land=document.getElementById('land-sel')?.value||'DE';const sub=cart.reduce((a,i)=>a+i.price*i.qty,0);const disc=calcDiscount(sub);const discSub=sub-disc;const shipNum=getShipping(land,discSub);const total=discSub+shipNum;const totalItems=cart.reduce((a,i)=>a+i.qty,0);
  if(!cart.length){body.innerHTML='<div style="text-align:center;padding:40px 16px;color:var(--muted)"><p style="font-size:10px">WARENKORB LEER</p></div>';}else{body.innerHTML=cart.map((it,i)=>`<div class="c-item"><div style="width:40px;height:40px;background:#f9f9f9;border-radius:4px;display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--primary);font-size:9px;font-weight:700">${it.name.substring(0,3)}</div><div class="c-item-info" style="flex:1"><h4 style="color:var(--primary)">${esc(it.name)}</h4><p style="color:var(--accent)">${(it.price*it.qty).toFixed(2)} €</p><div class="c-qty" style="margin-top:6px"><div class="qty-b" onclick="changeQty(${i},-1)">−</div><span style="font-size:9px;min-width:14px;text-align:center">${it.qty}</span><div class="qty-b" onclick="changeQty(${i},1)">+</div></div></div></div>`).join('');}
  document.getElementById('c-sub').innerText=sub.toFixed(2).replace('.',',')+' €';const dRow=document.getElementById('discount-row');if(disc>0){dRow.style.display='flex';document.getElementById('c-discount').innerText='-'+disc.toFixed(2).replace('.',',')+' €';}else{dRow.style.display='none';}document.getElementById('c-ship').innerText=shipNum===0?'Kostenlos':shipNum.toFixed(2).replace('.',',')+' €';document.getElementById('c-total').innerText=total.toFixed(2).replace('.',',')+' €';document.getElementById('cart-count').innerText=totalItems;
  renderPP(discSub,shipNum,land);
}
function renderPP(sub,ship,land){
  const c=document.getElementById('pp-btn-cont');c.innerHTML='';if(sub<=0||typeof paypal==='undefined')return;
  try{paypal.Buttons({style:{layout:'vertical',color:'blue',shape:'rect',label:'pay',height:40},onClick:(d,a)=>{if(!document.getElementById('cart-agb').checked){toast('AGB akzeptieren','ok');return a.reject();}},createOrder:(d,a)=>a.order.create({purchase_units:[{description:'LXRD WALLET Order',amount:{currency_code:'EUR',value:(sub+ship).toFixed(2),breakdown:{item_total:{currency_code:'EUR',value:sub.toFixed(2)},shipping:{currency_code:'EUR',value:ship.toFixed(2)}}},items:cart.map(i=>({name:i.name.substring(0,127),quantity:String(i.qty),unit_amount:{currency_code:'EUR',value:i.price.toFixed(2)},category:'PHYSICAL_GOODS'}))}]}),onApprove:(d,a)=>a.order.capture().then(det=>{const email=det.payer?.email_address||'';const fn=det.payer?.name?.given_name||'Kunde';const ln=det.payer?.name?.surname||'';const orderNr='LXRDW-'+Date.now().toString().slice(-6);processOrder(email,orderNr,fn,ln);showOrderSuccess(email,orderNr);}),onCancel:()=>toast('Zahlung abgebrochen','ok'),onError:(err)=>{console.error('PayPal:',err);toast('PayPal Fehler','ok');}}).render('#pp-btn-cont').catch(e=>console.warn('PayPal:',e));}catch(e){console.warn('PP:',e);}
}
function processOrder(email,orderNr,fn,ln){
  const sub=cart.reduce((a,i)=>a+i.price*i.qty,0);const disc=calcDiscount(sub);const land=document.getElementById('land-sel')?.value||'DE';const ship=getShipping(land,sub-disc);const total=sub-disc+ship;const name=(fn+' '+ln).trim();const itemList=cart.map(i=>`<tr><td style="padding:6px 0;border-bottom:1px solid #ddd;color:var(--muted)">${esc(i.name)}</td><td style="text-align:center;border-bottom:1px solid #ddd;color:var(--muted)">${i.qty}×</td><td style="text-align:right;border-bottom:1px solid #ddd;color:var(--accent);font-weight:600">${(i.price*i.qty).toFixed(2)} €</td></tr>`).join('');
  ejsSend(email,name,'✅ Bestellbestätigung '+orderNr,`<div style="background:#f9f9f9;color:var(--muted);font-family:Arial;font-size:10px;padding:20px"><h2 style="color:var(--primary);margin-bottom:16px">Bestellung Bestätigt</h2><p>Hallo <strong style="color:var(--accent)">${esc(name)}</strong>,</p><p>vielen Dank für dein Vertrauen! Deine Bestellung wird in den nächsten 24h versandt. Tracking folgt per E-Mail.</p><div style="background:#fff;border:1px solid #ddd;padding:16px;margin:16px 0;border-radius:4px"><div style="color:var(--accent);margin-bottom:10px;font-weight:600">Bestellnummer: ${orderNr}</div><table style="width:100%;border-collapse:collapse;margin:10px 0"><tr style="font-weight:600;border-bottom:1px solid #ddd;color:var(--primary)"><td>Artikel</td><td style="text-align:center">Menge</td><td style="text-align:right">Preis</td></tr>${itemList}</table><div style="border-top:1px solid #ddd;padding-top:10px;margin-top:10px"><div style="display:flex;justify-content:space-between;margin-bottom:4px"><span>Zwischensumme</span><span>${sub.toFixed(2)} €</span></div><div style="display:flex;justify-content:space-between;margin-bottom:4px"><span>Versand</span><span>${ship===0?'Kostenlos':ship.toFixed(2)+' €'}</span></div><div style="display:flex;justify-content:space-between;font-weight:600;color:var(--accent);border-top:1px solid #ddd;padding-top:8px"><span>Gesamt</span><span>${total.toFixed(2)} €</span></div></div></div></div>`,ADMIN_EMAIL).catch(e=>console.warn('Order email failed:',e));
  ejsSend(ADMIN_EMAIL,'LXRD Admin','[ORDER] '+orderNr+' · '+name+' · '+total.toFixed(2)+' €',`<div><strong style="color:var(--accent)">Order #${orderNr}</strong><br>Kunde: <strong>${esc(name)}</strong><br>Email: <a href="mailto:${esc(email)}">${esc(email)}</a><br>Gesamt: <strong>${total.toFixed(2)} €</strong></div>`,email).catch(e=>console.warn('Admin email failed:',e));
  cart=[];activeDiscount=null;saveCart();
}
function sendContact(e){
  e.preventDefault();const btn=document.getElementById('send-btn');btn.innerText='WIRD GESENDET…';btn.disabled=true;const name=document.getElementById('cf-name').value;const email=document.getElementById('cf-email').value;const message=document.getElementById('cf-message').value;
  ejsSend(ADMIN_EMAIL,'LXRD Admin','[KONTAKT] '+esc(name),`<div><strong style="color:var(--accent)">${esc(name)}</strong><br><a href="mailto:${esc(email)}">${esc(email)}</a><br><br>${esc(message)}</div>`,email).catch(e2=>console.warn('Contact failed:',e2));
  ejsSend(email,name,'✅ Nachricht erhalten | LXRD WALLET',`<div><p>Hallo <strong style="color:var(--accent)">${esc(name)}</strong>,</p><p>wir haben deine Nachricht erhalten und werden dir innerhalb von <strong>24 Stunden</strong> antworten. Vielen Dank für dein Vertrauen!</p></div>`,ADMIN_EMAIL).catch(e2=>console.warn('Reply failed:',e2));
  setTimeout(()=>{document.getElementById('contact-form').style.display='none';document.getElementById('contact-success').style.display='block';btn.innerText='NACHRICHT SENDEN';btn.disabled=false;},800);
}
function showOrderSuccess(email,orderNr){document.getElementById('success-email').innerText=email||'deiner Email';document.getElementById('success-order-nr').innerText='Bestellnummer: '+orderNr;document.getElementById('order-success-modal').style.display='flex';closeCart();}
function closeOrderSuccess(){document.getElementById('order-success-modal').style.display='none';updateCart();}
function toggleFaq(el){el.parentElement.classList.toggle('open');el.querySelector('span').innerText=el.parentElement.classList.contains('open')?'−':'+';}
function toast(msg,type){const t=document.createElement('div');t.className='toast '+type;t.innerText=msg;document.getElementById('toasts').appendChild(t);setTimeout(()=>{t.style.cssText='opacity:0;transform:translateX(60px);transition:.4s';setTimeout(()=>t.remove(),400);},3000);}
window.addEventListener('scroll',()=>{const el=document.getElementById('scroll-top');if(el)el.classList.toggle('vis',window.scrollY>400);});
const revObs=new IntersectionObserver((entries)=>{entries.forEach(en=>{if(en.isIntersecting){en.target.style.transition='opacity .9s ease, transform .9s ease';en.target.style.opacity='1';en.target.style.transform='translateY(0)';revObs.unobserve(en.target);}});},{threshold:.08,rootMargin:'0px 0px -40px 0px'});
document.querySelectorAll('.reveal').forEach(el=>revObs.observe(el));
loadCart();updateCart();
</script>

</body>
</html>
